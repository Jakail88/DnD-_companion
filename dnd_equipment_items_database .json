    "Magic_Items": {
        "Bag of Holding": {
            "rarity": "Uncommon",
            "attunement": false,
            "description": "Questo sacco ha uno spazio interdimensionale interno molto più grande delle sue dimensioni esterne, in grado di contenere fino a 230 kg (500 libbre) per un volume totale di 1,8 metri cubi. Pesa sempre 7 kg indipendentemente dal suo contenuto.",
            "source": "Dungeon Master's Guide"
        },
        "Decanter of Endless Water": {
            "rarity": "Uncommon",
            "attunement": false,
            "description": "Una boccetta che se stappata può spruzzare acqua fresca o salata su comando. Ha tre parole d'ordine: 'Stream' (crea un ruscello d'acqua), 'Fountain' (un getto continuo) o 'Geyser' (un violento spruzzo d'acqua lungo 9 metri, utilizzabile per spingere indietro i nemici).",
            "source": "Dungeon Master's Guide"
        },
        "Mizzium Apparatus": {
            "rarity": "Uncommon",
            "attunement": true,
            "classes_req": [
                "Sorcerer",
                "Warlock",
                "Wizard"
            ],
            "description": "Un bizzarro dispositivo metallico della gilda Izzet. Consente a un incantatore di lanciare qualsiasi incantesimo presente sulla sua lista di classe (anche se non conosciuto o preparato) superando una prova di Intelligenza (Arcana) con CD pari a 10 + il doppio del livello dello slot incantesimo utilizzato.",
            "source": "Guildmasters' Guide to Ravnica"
        },
        "Pyroconverger": {
            "rarity": "Uncommon",
            "attunement": true,
            "description": "Un dispositivo portatile Izzet che funge da lanciafiamme. Come azione, puoi sparare una linea di fiamme di 15 piedi: ogni creatura nell'area deve superare un tiro salvezza su Destrezza (CD 13) o subire 4d6 danni da fuoco. C'è un rischio di surriscaldamento ed esplosione ad ogni uso.",
            "source": "Guildmasters' Guide to Ravnica"
        },
        "Staff of the Magi": {
            "rarity": "Legendary",
            "attunement": true,
            "classes_req": [
                "Sorcerer",
                "Warlock",
                "Wizard"
            ],
            "description": "Un bastone leggendario che conferisce +2 ai tiri per colpire, ai danni con armi e alla CD dei tiri salvezza degli incantesimi. Contiene 50 cariche utilizzabili per lanciare decine di magie (come Palla di Fuoco, Fulmine, ecc.). Consente inoltre di assorbire incantesimi nemici diretti contro di te o di eseguire un Colpo di Grazia (Retributive Strike) spaccando il bastone con conseguenze apocalittiche.",
            "source": "Dungeon Master's Guide"
        },
        "Vorpal Sword": {
            "rarity": "Legendary",
            "attunement": true,
            "description": "Questa spada magica concede un bonus di +3 ai tiri per colpire e ai danni. Quando ottieni un 20 naturale sul tiro per colpire con quest'arma, decapiti istantaneamente il bersaglio (se ha una testa ed è vulnerabile a questa meccanica), infliggendo in caso contrario 6d8 danni taglienti extra.",
            "source": "Dungeon Master's Guide"
        }
    }
